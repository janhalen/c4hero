# Optional: enable secure HMR when developing through a tunnel or reverse proxy
# that terminates TLS. Leave unset for normal localhost development.
# VITE_HMR_TUNNEL=1

# Optional: send warn/error logs to an HTTPS endpoint with navigator.sendBeacon.
# If you set this for a hosted build, also add the endpoint origin to your CSP
# connect-src policy.
# VITE_LOG_ENDPOINT=https://logs.example.com/c4hero

# Optional hosted-app analytics. Leave unset for local/self-hosted builds that
# should not load third-party analytics. The app respects Global Privacy Control,
# Do Not Track, and the c4hero:observability:disabled localStorage opt-out. The
# in-app beacon is disabled on /collection/* and uses spa:false so editor route
# slugs are not sent through Cloudflare Web Analytics.
# VITE_CLOUDFLARE_ANALYTICS_TOKEN=00000000000000000000000000000000

# Optional hosted-app error reporting. Leave unset to disable Sentry. The
# integration sends no default PII, strips query strings/fragments, redacts
# collection/workspace/view route slugs, and does not enable session replay.
# VITE_SENTRY_DSN=https://public-key@o000000.ingest.us.sentry.io/000000
# VITE_SENTRY_ENVIRONMENT=production

# Optional: extra hostnames the Vite dev server will accept (comma-separated),
# e.g. when developing through a tunnel or reverse-proxy domain. Leave unset
# for normal localhost development.
# VITE_ALLOWED_HOSTS=dev.example.com,app.example.com
